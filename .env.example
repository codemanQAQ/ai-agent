# =============================================================================
# .env.example  (committed to git, 模板文件)
# 复制为 .env 并填入真实凭证后即可本地运行。
# 真实 .env 已在 .gitignore，不会被提交。
# 加载方式：application.properties 通过 spring.config.import=optional:file:./.env[.properties]
# 写法：properties 风格点号 key，与 application.properties 完全一致。
# =============================================================================

# ---------- Application ----------
spring.application.name=rag-backend-dev
server.port=8080
server.servlet.context-path=/api/v1
logging.pattern.console=%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5p ${PID: } --- [${spring.application.name}] [%15.15t] %-40.40logger{39} : %m %kvp%n%wEx
spring.threads.virtual.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=20MB

# ---------- Datasource (PostgreSQL 18.x) ----------
spring.datasource.url=jdbc:postgresql://your-db-host:5432/your-db-name?sslmode=require
spring.datasource.username=your-db-username
spring.datasource.password=your-db-password
spring.datasource.driver-class-name=org.postgresql.Driver
spring.sql.init.mode=always
spring.sql.init.schema-locations=classpath:db/migration/schema.sql

# ---------- Mail (SMTP) ----------
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your-smtp-username@example.com
spring.mail.password=your-smtp-app-password
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.transport.protocol=smtp

# ---------- RAG Notification ----------
rag.notification.final-failure-email.enabled=true
rag.notification.final-failure-email.from=your-from@example.com
rag.notification.final-failure-email.subject-prefix=[RAG]
rag.notification.final-failure-email.base-url=https://your-domain.com
rag.notification.message-parse-failure-email.enabled=true
rag.notification.message-parse-failure-email.from=your-from@example.com
rag.notification.message-parse-failure-email.recipients=
rag.notification.message-parse-failure-email.subject-prefix=[RAG]
rag.notification.message-parse-failure-email.base-url=https://your-domain.com

# ---------- OpenAI 兼容 LLM ----------
# 默认走 OpenAI / 通义；切换到 Doubao（火山方舟）只需改 base-url + model id + dimension。
# 示例（注释项保留以便快速切换）：
#   spring.ai.openai.api-key=ark-xxxxxxxxxxxxxxxx
#   spring.ai.openai.base-url=https://ark.cn-beijing.volces.com/api/v3
#   spring.ai.openai.embedding.model=doubao-embedding-vision-250328
#   spring.ai.openai.embedding.dimensions=2048
#   rag.milvus.embedding-dimension=2048
spring.ai.openai.api-key=your-openai-compatible-api-key
spring.ai.openai.base-url=https://your-openai-compatible-endpoint/v1
spring.ai.openai.embedding.model=text-embedding-v3
spring.ai.openai.embedding.dimensions=1024
# 重要：rag.milvus.embedding-dimension 必须与 spring.ai.openai.embedding.dimensions 一致，
# 否则索引写入会成功但检索阶段会因维度不匹配抛错。

# ---------- RAG Base ----------
rag.default-top-k=6
rag.chunk-size=400
rag.chunk-overlap=80
rag.embedding-model=text-embedding-v3

# ---------- RAG Indexing ----------
rag.indexing.max-retries=3
rag.indexing.retry-backoff-millis=1000
rag.indexing.embedding-cache-enabled=true

# ---------- RAG Query Expansion ----------
rag.query-expansion.enabled=true
rag.query-expansion.use-model=true
rag.query-expansion.include-original=true
rag.query-expansion.number-of-queries=3
rag.query-expansion.timeout-millis=2000

# ---------- RAG Query Transformation ----------
rag.query-transformation.enabled=true
rag.query-transformation.use-model=true
rag.query-transformation.min-conversation-turns=3
rag.query-transformation.query-template=
rag.query-transformation.min-question-length=0
rag.query-transformation.min-question-tokens=0
rag.query-transformation.min-history-turns=0
rag.query-transformation.timeout-millis=2000
rag.query-transformation.rewrite-enabled=true
rag.query-transformation.rewrite-use-model=true
rag.query-transformation.rewrite-query-template=
rag.query-transformation.rewrite-target-search-system=

# ---------- RAG Retrieval ----------
rag.retrieval.keyword-heading-weight=4.0
rag.retrieval.keyword-title-weight=1.5
rag.retrieval.keyword-content-weight=1.0
rag.retrieval.semantic-heading-weight=0.25
rag.retrieval.keyword-candidate-multiplier=8
rag.retrieval.keyword-candidate-top-k-max=100
rag.retrieval.hybrid-per-retriever-multiplier=2
rag.retrieval.hybrid-per-retriever-top-k-max=20
rag.retrieval.multi-query-per-query-multiplier=2
rag.retrieval.multi-query-per-query-top-k-max=10
rag.retrieval.semantic-candidate-multiplier=3
rag.retrieval.semantic-filtered-candidate-multiplier=5
rag.retrieval.semantic-candidate-top-k-max=50
rag.retrieval.rrf-k=60.0
rag.retrieval.neighbor-window-before=1
rag.retrieval.neighbor-window-after=1
rag.retrieval.semantic-timeout-millis=1500
rag.retrieval.keyword-timeout-millis=1500
rag.retrieval.query-timeout-millis=3000
rag.retrieval.answer-generation-timeout-millis=12000

# ---------- RocketMQ 5.x ----------
rag.rocketmq.enabled=true
rag.rocketmq.endpoints=your-rocketmq-host:8081
rag.rocketmq.topic=your-rag-index-topic
rag.rocketmq.tag=your-rag-index-tag
rag.rocketmq.max-attempt-times=3
rag.rocketmq.consumer-group=your-rag-index-consumer-group
rocketmq.producer.ssl-enabled=false
rag.rocketmq.request-timeout-seconds=15
rag.rocketmq.ssl-enabled=false
rag.rocketmq.parse-failure-alert-threshold=3
rag.rocketmq.parse-failure-payload-preview-length=1000

# ---------- Outbox ----------
rag.outbox.enabled=true
rag.outbox.retry-backoff-millis=10000
rag.outbox.batch-size=20
rag.outbox.dispatch-fixed-delay-millis=3000
rag.outbox.sending-stale-millis=60000

# ---------- Recovery ----------
rag.recovery.enabled=true
rag.recovery.deleting-stale-millis=60000
rag.recovery.failed-retry-millis=3600000
rag.recovery.processing-stale-millis=600000
rag.recovery.batch-size=20
rag.recovery.fixed-delay-millis=60000

# ---------- Milvus / Zilliz ----------
rag.milvus.enabled=true
rag.milvus.uri=https://your-milvus-or-zilliz-endpoint
rag.milvus.token=your-milvus-token
rag.milvus.database-name=
rag.milvus.collection-name=rag_chunks
rag.milvus.embedding-dimension=1024
rag.milvus.similarity-threshold=0.2

# ---------- Actuator / OTel ----------
management.tracing.sampling.probability=0.0
management.otlp.metrics.export.enabled=false
management.opentelemetry.logging.export.enabled=false
management.opentelemetry.tracing.export.enabled=false
