# =============================================================================
# .env.example
# 由 src/main/resources/application-dev.properties 派生而来
# 真实密钥 / 凭证 / 资源地址 均替换为占位符(your-xxx)，请勿提交真实值到 git
# Spring Boot 通过 relaxed binding 将下述 ENV 变量映射到 application.properties
# =============================================================================

# ---------- Application ----------
SPRING_APPLICATION_NAME=rag-backend-dev
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# 开发环境控制台日志格式
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5p ${PID: } --- [${spring.application.name}] [%15.15t] %-40.40logger{39} : %m %kvp%n%wEx

# 虚拟线程
SPRING_THREADS_VIRTUAL_ENABLED=true

# Multipart 上传限制
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=20MB

# ---------- Datasource (PostgreSQL) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/your-db-name?sslmode=require
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_SQL_INIT_MODE=always
SPRING_SQL_INIT_SCHEMA_LOCATIONS=classpath:db/migration/schema.sql

# ---------- Actuator ----------
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,loggers
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.0
MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=false
MANAGEMENT_OPENTELEMETRY_LOGGING_EXPORT_ENABLED=false
MANAGEMENT_OPENTELEMETRY_TRACING_EXPORT_ENABLED=false

# ---------- Mail (SMTP) ----------
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-smtp-username@example.com
SPRING_MAIL_PASSWORD=your-smtp-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_TRANSPORT_PROTOCOL=smtp

# ---------- RAG Notification ----------
RAG_NOTIFICATION_FINAL_FAILURE_EMAIL_ENABLED=true
RAG_NOTIFICATION_FINAL_FAILURE_EMAIL_FROM=your-from@example.com
RAG_NOTIFICATION_FINAL_FAILURE_EMAIL_SUBJECT_PREFIX=[RAG]
RAG_NOTIFICATION_FINAL_FAILURE_EMAIL_BASE_URL=https://your-domain.com
RAG_NOTIFICATION_MESSAGE_PARSE_FAILURE_EMAIL_ENABLED=true
RAG_NOTIFICATION_MESSAGE_PARSE_FAILURE_EMAIL_FROM=your-from@example.com
RAG_NOTIFICATION_MESSAGE_PARSE_FAILURE_EMAIL_RECIPIENTS=
RAG_NOTIFICATION_MESSAGE_PARSE_FAILURE_EMAIL_SUBJECT_PREFIX=[RAG]
RAG_NOTIFICATION_MESSAGE_PARSE_FAILURE_EMAIL_BASE_URL=https://your-domain.com

# ---------- OpenAI 兼容 LLM (DashScope / 自托管) ----------
SPRING_AI_OPENAI_API_KEY=your-openai-compatible-api-key
SPRING_AI_OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
SPRING_AI_OPENAI_EMBEDDING_MODEL=text-embedding-v3
SPRING_AI_OPENAI_EMBEDDING_DIMENSIONS=1024

# ---------- RAG Base ----------
RAG_DEFAULT_TOP_K=6
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=80
RAG_EMBEDDING_MODEL=text-embedding-v3

# ---------- RAG Indexing ----------
RAG_INDEXING_MAX_RETRIES=3
RAG_INDEXING_RETRY_BACKOFF_MILLIS=1000
RAG_INDEXING_EMBEDDING_CACHE_ENABLED=true

# ---------- RAG Query Expansion ----------
RAG_QUERY_EXPANSION_ENABLED=true
RAG_QUERY_EXPANSION_USE_MODEL=true
RAG_QUERY_EXPANSION_INCLUDE_ORIGINAL=true
RAG_QUERY_EXPANSION_NUMBER_OF_QUERIES=3
RAG_QUERY_EXPANSION_TIMEOUT_MILLIS=2000

# ---------- RAG Query Transformation ----------
RAG_QUERY_TRANSFORMATION_ENABLED=true
RAG_QUERY_TRANSFORMATION_USE_MODEL=true
RAG_QUERY_TRANSFORMATION_MIN_CONVERSATION_TURNS=3
RAG_QUERY_TRANSFORMATION_QUERY_TEMPLATE=
RAG_QUERY_TRANSFORMATION_MIN_QUESTION_LENGTH=0
RAG_QUERY_TRANSFORMATION_MIN_QUESTION_TOKENS=0
RAG_QUERY_TRANSFORMATION_MIN_HISTORY_TURNS=0
RAG_QUERY_TRANSFORMATION_TIMEOUT_MILLIS=2000
RAG_QUERY_TRANSFORMATION_REWRITE_ENABLED=true
RAG_QUERY_TRANSFORMATION_REWRITE_USE_MODEL=true
RAG_QUERY_TRANSFORMATION_REWRITE_QUERY_TEMPLATE=
RAG_QUERY_TRANSFORMATION_REWRITE_TARGET_SEARCH_SYSTEM=

# ---------- RAG Retrieval ----------
RAG_RETRIEVAL_KEYWORD_HEADING_WEIGHT=4.0
RAG_RETRIEVAL_KEYWORD_TITLE_WEIGHT=1.5
RAG_RETRIEVAL_KEYWORD_CONTENT_WEIGHT=1.0
RAG_RETRIEVAL_SEMANTIC_HEADING_WEIGHT=0.25
RAG_RETRIEVAL_KEYWORD_CANDIDATE_MULTIPLIER=8
RAG_RETRIEVAL_KEYWORD_CANDIDATE_TOP_K_MAX=100
RAG_RETRIEVAL_HYBRID_PER_RETRIEVER_MULTIPLIER=2
RAG_RETRIEVAL_HYBRID_PER_RETRIEVER_TOP_K_MAX=20
RAG_RETRIEVAL_MULTI_QUERY_PER_QUERY_MULTIPLIER=2
RAG_RETRIEVAL_MULTI_QUERY_PER_QUERY_TOP_K_MAX=10
RAG_RETRIEVAL_SEMANTIC_CANDIDATE_MULTIPLIER=3
RAG_RETRIEVAL_SEMANTIC_FILTERED_CANDIDATE_MULTIPLIER=5
RAG_RETRIEVAL_SEMANTIC_CANDIDATE_TOP_K_MAX=50
RAG_RETRIEVAL_RRF_K=60.0
RAG_RETRIEVAL_NEIGHBOR_WINDOW_BEFORE=1
RAG_RETRIEVAL_NEIGHBOR_WINDOW_AFTER=1
RAG_RETRIEVAL_SEMANTIC_TIMEOUT_MILLIS=1500
RAG_RETRIEVAL_KEYWORD_TIMEOUT_MILLIS=1500
RAG_RETRIEVAL_QUERY_TIMEOUT_MILLIS=3000
RAG_RETRIEVAL_ANSWER_GENERATION_TIMEOUT_MILLIS=12000

# ---------- RocketMQ ----------
RAG_ROCKETMQ_ENABLED=true
RAG_ROCKETMQ_ENDPOINTS=your-rocketmq-host:8081
RAG_ROCKETMQ_TOPIC=your-rag-index-topic
RAG_ROCKETMQ_TAG=your-rag-index-tag
RAG_ROCKETMQ_MAX_ATTEMPT_TIMES=3
RAG_ROCKETMQ_CONSUMER_GROUP=your-rag-index-consumer-group
RAG_ROCKETMQ_REQUEST_TIMEOUT_SECONDS=15
RAG_ROCKETMQ_SSL_ENABLED=false
RAG_ROCKETMQ_PARSE_FAILURE_ALERT_THRESHOLD=3
RAG_ROCKETMQ_PARSE_FAILURE_PAYLOAD_PREVIEW_LENGTH=1000
ROCKETMQ_PRODUCER_SSL_ENABLED=false

# ---------- Outbox ----------
RAG_OUTBOX_ENABLED=true
RAG_OUTBOX_RETRY_BACKOFF_MILLIS=10000
RAG_OUTBOX_BATCH_SIZE=20
RAG_OUTBOX_DISPATCH_FIXED_DELAY_MILLIS=3000
RAG_OUTBOX_SENDING_STALE_MILLIS=60000

# ---------- Recovery ----------
RAG_RECOVERY_ENABLED=true
RAG_RECOVERY_DELETING_STALE_MILLIS=60000
RAG_RECOVERY_FAILED_RETRY_MILLIS=3600000
RAG_RECOVERY_PROCESSING_STALE_MILLIS=600000
RAG_RECOVERY_BATCH_SIZE=20
RAG_RECOVERY_FIXED_DELAY_MILLIS=60000

# ---------- Milvus / Zilliz ----------
RAG_MILVUS_ENABLED=true
RAG_MILVUS_URI=https://your-milvus-or-zilliz-endpoint
RAG_MILVUS_TOKEN=your-milvus-token
RAG_MILVUS_DATABASE_NAME=
RAG_MILVUS_COLLECTION_NAME=rag_chunks
RAG_MILVUS_EMBEDDING_DIMENSION=1024
RAG_MILVUS_SIMILARITY_THRESHOLD=0.2
